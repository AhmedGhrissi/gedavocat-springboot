# ============================================================
# DocAvocat  .gitignore
# Seuls les fichiers essentiels au fonctionnement de l'app
# sont versionnes. Tout le reste est exclu.
# ============================================================

# -- Compiled / Build ----------------------------------------
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
target/

# -- Maven ---------------------------------------------------
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# -- IDE -----------------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/
.classpath
.project
.settings/
bin/
nb-configuration.xml
.vscode/
*.ctxt

# -- OS ------------------------------------------------------
.DS_Store
Thumbs.db

# -- Logs ----------------------------------------------------
*.log
logs/

# -- Environment / Secrets -----------------------------------
.env
.env.*
!.env.example

# -- SQL dumps et migrations ponctuelles ---------------------
*.sql
!docker/init/01-schema.sql
!docker/init/02-migration-version-columns.sql

# -- Python --------------------------------------------------
.venv*/
__pycache__/
*.pyc
*.py

# -- PDFs et rapports generes --------------------------------
*.pdf

# -- Documentation dev non essentielle -----------------------
AMELIORATIONS_*.md
CHECKLIST_*.txt
CORRECTIONS_*.txt
CORRECTIONS_*.md
DESIGN_*.md
GUIDE_*.md
GUIDE_*.txt
GUIDE-*.md
RECAP_*.txt
RECAP_*.md
RESUME_*.txt
RESUME-*.md
UNIFORMISATION_*.md
QA-AUDIT-REPORT.md
SECURITY-AUDIT-REPORT.md

# -- Backups -------------------------------------------------
backup/

# -- Scripts de dev/test locaux ------------------------------
*.bat
test_*.sh

# -- Docker artefacts non essentiels -------------------------
Dockerfile.hotfix
Dockerfile.prod

# -- Node / Playwright / Tests E2E --------------------------
node_modules/
npm-debug.log
yarn-error.log
tests/
test-results/
playwright-report/
playwright/.cache/

# -- H2 Database --------------------------------------------
*.db

# -- Gradle (unused) ----------------------------------------
.gradle/
build/

# -- JVM crash logs -----------------------------------------
hs_err_pid*
.mtj.tmp/

# -- Misc legacy ---------------------------------------------
application-o2switch.properties
uploads/
temp/
