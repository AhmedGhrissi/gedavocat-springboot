# ============================================================
# DocAvocat — Variables d'environnement de production
#
# Ce fichier est un TEMPLATE. Il est commité dans git.
# Copier en .env.prod et remplir les vraies valeurs.
#
#   cp .env.example .env.prod
#
# ⚠️  NE JAMAIS committer .env.prod dans git !
# ============================================================

# ── MySQL ───────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_PASSWORD=changeme_gedavocat

# ── JWT ─────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=changeme_very_long_secret_key

# ── Email SMTP ──────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@docavocat.fr
MAIL_PASSWORD=changeme_mail_password

# ── Application ─────────────────────────────────────────────
MAINTENANCE_ENABLED=false

# ── Docker ──────────────────────────────────────────────────
# GID du groupe docker sur le serveur
# Obtenir avec : stat -c '%g' /var/run/docker.sock
DOCKER_GID=988

# ── Image Docker ────────────────────────────────────────────
# Injecté automatiquement par la CI lors du déploiement.
# Pour un premier déploiement manuel, spécifier l'image complète :
# APP_IMAGE=registry.gitlab.com/<namespace>/<projet>:latest
APP_IMAGE=registry.gitlab.com/NAMESPACE/PROJET:latest
