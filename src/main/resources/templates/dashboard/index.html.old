<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
      xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
      xmlns:sec="http://www.thymeleaf.org/extras/spring-security"
      layout:decorate="~{layout}">
<head>
    <link rel="stylesheet" th:href="@{/css/pages/dashboard.css}">
    <title>Tableau de bord</title>
</head>
<body>
    <div layout:fragment="content">
        <div class="container-fluid">

            <!-- ═══════════ HERO BANNER ═══════════ -->
            <div class="hero-banner">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                    <div>
                        <h1>
                            Bonjour,
                            <span th:if="${user.role != null and (user.role.name() == 'LAWYER' or user.role.name() == 'LAWYER_SECONDARY')}"
                                  th:text="${(user.lastName != null or user.firstName != null) ? 'Maître ' + (user.lastName != null ? user.lastName : '') + (user.firstName != null ? ' ' + user.firstName : '') : user.name}">Maître Dupont Jean</span>
                            <span th:unless="${user.role != null and (user.role.name() == 'LAWYER' or user.role.name() == 'LAWYER_SECONDARY')}"
                                  th:text="${user.name}">Utilisateur</span>
                        </h1>
                        <p>
                            <span th:text="'Connecté en tant que ' + ${user.role.displayName}">Connecté en tant que avocat</span>
                            &nbsp;·&nbsp;
                            <span th:text="${T(java.time.format.DateTimeFormatter).ofPattern('EEEE d MMMM yyyy', T(java.util.Locale).FRENCH).format(T(java.time.LocalDate).now())}">lundi 1 janvier 2025</span>
                        </p>
                    </div>
                    <div>
                        <span th:if="${user.hasActiveSubscription()}" class="subscription-badge badge-active">
                            <i class="fas fa-check-circle"></i>
                            <span>Abonnement actif</span>
                        </span>
                        <span th:if="${!user.hasActiveSubscription()}" class="subscription-badge badge-inactive">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span>Pas d'abonnement</span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- ═══════════ SUBSCRIPTION ALERTS ═══════════ -->
            <div class="alert alert-success mb-4" th:if="${user.hasActiveSubscription()}">
                <i class="fas fa-shield-check"></i>
                <div class="d-flex justify-content-between align-items-center flex-grow-1 flex-wrap gap-2">
                    <div>
                        <strong>Plan actif</strong> —
                        <span class="badge bg-primary" th:text="${user.subscriptionPlan != null ? user.subscriptionPlan.displayName : ''}">CABINET</span>
                        <span th:if="${user.subscriptionEndsAt != null}">
                            jusqu'au <strong th:text="${#temporals.format(user.subscriptionEndsAt, 'dd/MM/yyyy')}">31/12/2024</strong>
                        </span>
                        <span th:if="${user.daysRemaining > 0 and user.daysRemaining < 30}"
                              class="badge bg-warning">
                            <i class="fas fa-clock"></i> Expire dans <span th:text="${user.daysRemaining}">7</span> j
                        </span>
                    </div>
                    <a th:href="@{/payment/manage}" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-cog"></i> Gérer
                    </a>
                </div>
            </div>

            <div class="alert alert-warning mb-4" th:if="${!user.hasActiveSubscription()}">
                <i class="fas fa-exclamation-triangle"></i>
                <div class="d-flex justify-content-between align-items-center flex-grow-1 flex-wrap gap-2">
                    <div>
                        <strong>Aucun abonnement</strong> — Activez toutes les fonctionnalités
                    </div>
                    <a th:href="@{/payment/pricing}" class="btn btn-warning btn-sm">
                        <i class="fas fa-crown"></i> Choisir un plan
                    </a>
                </div>
            </div>

            <!-- ═══════════ STAT CARDS ═══════════ -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-lg-3">
                    <div class="stat-card">
                        <div class="stat-icon blue"><i class="fas fa-folder-open"></i></div>
                        <div class="stat-value" th:text="${activeCases != null ? activeCases : 0}">0</div>
                        <div class="stat-label">Dossiers actifs</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="stat-card">
                        <div class="stat-icon green"><i class="fas fa-users"></i></div>
                        <div class="stat-value" th:text="${clientsCount != null ? clientsCount : 0}">0</div>
                        <div class="stat-label">Clients</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="stat-card">
                        <div class="stat-icon orange"><i class="fas fa-file-lines"></i></div>
                        <div class="stat-value" th:text="${documentsCount != null ? documentsCount : 0}">0</div>
                        <div class="stat-label">Documents</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="stat-card">
                        <div class="stat-icon gold"><i class="fas fa-file-signature"></i></div>
                        <div class="stat-value" th:text="${signaturesCount != null ? signaturesCount : 0}">0</div>
                        <div class="stat-label">Signatures en cours</div>
                    </div>
                </div>
            </div>

            <!-- ═══════════ MAIN GRID ═══════════ -->
            <div class="row g-4">
                <!-- LEFT: Quick Actions + Recent Cases -->
                <div class="col-lg-8">
                    <!-- Quick Actions -->
                    <h3 class="section-title">
                        <i class="fas fa-bolt"></i> Actions rapides
                    </h3>
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <a th:href="@{/cases/new}" class="quick-action blue">
                                <div class="action-icon"><i class="fas fa-plus"></i></div>
                                <div>
                                    <div class="action-title">Nouveau dossier</div>
                                    <div class="action-desc">Créer un nouveau dossier client</div>
                                </div>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a th:href="@{/clients/new}" class="quick-action green">
                                <div class="action-icon"><i class="fas fa-user-plus"></i></div>
                                <div>
                                    <div class="action-title">Nouveau client</div>
                                    <div class="action-desc">Ajouter un nouveau client</div>
                                </div>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a th:href="@{/signatures/new}" class="quick-action amber">
                                <div class="action-icon"><i class="fas fa-file-signature"></i></div>
                                <div>
                                    <div class="action-title">Demander signature</div>
                                    <div class="action-desc">Signature électronique Yousign</div>
                                </div>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a th:href="@{/rpva}" class="quick-action gold">
                                <div class="action-icon"><i class="fas fa-gavel"></i></div>
                                <div>
                                    <div class="action-title">Communication RPVA</div>
                                    <div class="action-desc">e-Barreau / Juridictions</div>
                                </div>
                            </a>
                        </div>
                    </div>

                    <!-- Recent Cases -->
                    <h3 class="section-title">
                        <i class="fas fa-file-signature"></i> Signatures récentes
                    </h3>
                    <div class="card mb-4">
                        <div class="card-body p-0">
                            <div th:if="${recentSignatures != null and !recentSignatures.isEmpty()}">
                                <div class="d-flex gap-3 px-4 py-2 signatures-header">
                                    <span class="badge bg-warning" th:text="'En attente : ' + ${pendingSignatures}">En attente : 0</span>
                                    <span class="badge bg-success" th:text="'Signés : ' + ${signedSignatures}">Signés : 0</span>
                                </div>
                                <div th:each="sig,iter : ${recentSignatures}"
                                     class="signature-item"
                                     th:classappend="${!iter.last ? 'border-bottom' : ''}">
                                    <div class="signature-icon"
                                         th:classappend="${sig.status.name() == 'SIGNED'} ? 'success' : (${sig.status.name() == 'PENDING'} ? 'warning' : 'secondary')">
                                        <i th:class="${sig.status.name() == 'SIGNED'} ? 'fas fa-check' : (${sig.status.name() == 'PENDING'} ? 'fas fa-hourglass-half' : 'fas fa-times')"></i>
                                    </div>
                                    <div class="signature-info">
                                        <div class="signature-name">
                                            <a th:href="@{/signatures/{id}(id=${sig.id})}" th:text="${sig.documentName}">Document</a>
                                        </div>
                                        <div class="signature-meta" th:text="${sig.signerName + ' · ' + sig.signerEmail}">Signataire</div>
                                    </div>
                                    <span class="badge"
                                          th:classappend="${sig.status.name() == 'SIGNED'} ? 'bg-success' :
                                                         (${sig.status.name() == 'PENDING'} ? 'bg-warning' :
                                                         (${sig.status.name() == 'REJECTED'} ? 'bg-danger' : 'bg-secondary'))"
                                          th:text="${sig.status.displayName}">Statut</span>
                                    <span class="signature-date" th:text="${#temporals.format(sig.createdAt, 'dd/MM/yyyy')}">Date</span>
                                </div>
                            </div>
                            <div th:if="${recentSignatures == null or recentSignatures.isEmpty()}" class="empty-state">
                                <div class="empty-icon">
                                    <i class="fas fa-file-signature"></i>
                                </div>
                                <p>Aucune signature</p>
                                <a th:href="@{/signatures/new}" class="btn btn-primary btn-sm mt-2">
                                    <i class="fas fa-plus"></i> Nouvelle signature
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Dossiers récents -->
                    <h3 class="section-title">
                        <i class="fas fa-folder"></i> Dossiers récents
                    </h3>
                    <div class="card">
                        <div class="card-body p-0">
                            <div th:if="${recentCases != null and !recentCases.isEmpty()}">
                                <div th:each="caseItem,iter : ${recentCases}"
                                     class="case-item"
                                     th:classappend="${!iter.last ? 'border-bottom' : ''}">
                                    <div class="case-thumb">
                                        <i class="fas fa-folder"></i>
                                    </div>
                                    <div class="case-info">
                                        <div class="case-name">
                                            <a th:href="@{/cases/{id}(id=${caseItem.id})}" th:text="${caseItem.name}">Dossier</a>
                                        </div>
                                        <div class="case-meta" th:text="${caseItem.client != null ? caseItem.client.name : 'Non assigné'}">Client</div>
                                    </div>
                                    <span class="case-status"
                                          th:classappend="${caseItem.status.name() == 'OPEN' ? 'open' : (caseItem.status.name() == 'IN_PROGRESS' ? 'in-progress' : (caseItem.status.name() == 'CLOSED' ? 'closed' : 'archived'))}"
                                          th:text="${caseItem.status.displayName}">Statut</span>
                                    <span class="case-date" th:text="${#temporals.format(caseItem.createdAt, 'dd/MM/yyyy')}">Date</span>
                                </div>
                            </div>
                            <div th:if="${recentCases == null or recentCases.isEmpty()}" class="empty-state">
                                <div class="empty-icon">
                                    <i class="fas fa-folder-open"></i>
                                </div>
                                <h5>Aucun dossier</h5>
                                <p>Créez votre premier dossier pour commencer</p>
                                <a th:href="@{/cases/new}" class="btn btn-primary btn-sm mt-2">
                                    <i class="fas fa-plus"></i> Créer un dossier
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: Activity Feed -->
                <div class="col-lg-4">
                    <h3 class="section-title">
                        <i class="fas fa-clock-rotate-left" style="color:var(--brand-500);font-size:14px"></i> Activité récente
                    </h3>
                    <div class="card" style="min-height:300px">
                        <div class="card-body">
                            <div th:if="${recentActivities != null and !recentActivities.isEmpty()}">
                                <div th:each="activity : ${recentActivities}" class="mb-3">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="activity-dot"></div>
                                        <div style="min-width:0">
                                            <div class="activity-text" th:text="${activity.title}">Nouveau document</div>
                                            <div class="activity-desc" th:text="${activity.description}">contrat.pdf ajouté</div>
                                            <div class="activity-time" th:text="${activity.time}">Il y a 2 heures</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div th:unless="${recentActivities != null and !#lists.isEmpty(recentActivities)}" class="text-center py-4">
                                <div style="width:56px;height:56px;border-radius:var(--radius-xl);background:linear-gradient(135deg,var(--bg-secondary),var(--bg-tertiary));display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px">
                                    <i class="fas fa-inbox fa-lg" style="color:var(--text-tertiary)"></i>
                                </div>
                                <p style="color:var(--text-secondary);font-size:14px;margin:0">Aucune activité récente</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
