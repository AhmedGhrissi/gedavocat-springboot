<!DOCTYPE html>
<html lang="fr" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion — DocAvocat</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link th:href="@{/webjars/bootstrap/5.3.0/css/bootstrap.min.css}" rel="stylesheet">
    <link th:href="@{/webjars/font-awesome/6.4.0/css/all.min.css}" rel="stylesheet">
    <link th:href="@{/css/pages/auth.css}" rel="stylesheet">
</head>
<body>
    <!-- Left Panel — Brand Hero -->
    <div class="auth-left">
        <div class="brand-logo">
            <div class="brand-icon"><i class="fas fa-scale-balanced"></i></div>
            <span class="brand-name">DocAvocat</span>
        </div>
        <div class="auth-left-content">
            <h2>Espace professionnel<br>sécurisé</h2>
            <p>Portail de gestion documentaire dédié aux cabinets d'avocats.</p>
            <ul class="features-list">
                <li>
                    <div class="feature-icon"><i class="fas fa-folder-open"></i></div>
                    Gestion centralisée des dossiers
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-file-signature"></i></div>
                    Signatures électroniques Yousign
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-shield-halved"></i></div>
                    Sécurité et conformité RGPD
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-gavel"></i></div>
                    Intégration RPVA / e-Barreau
                </li>
            </ul>
        </div>
    </div>

    <!-- Right Panel — Login Form -->
    <div class="auth-right">
        <h1>Accès au portail</h1>
        <p class="subtitle">Connectez-vous à votre espace DocAvocat</p>

        <div th:if="${param.error}" class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            <span th:text="${error} ?: 'Email ou mot de passe incorrect'"></span>
        </div>

        <div th:if="${message}" class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            <span th:text="${message}"></span>
        </div>

        <form th:action="@{/login}" method="post">
            <div class="form-group">
                <label class="form-label" for="email">Adresse e-mail</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input type="email"
                           id="email"
                           name="email"
                           class="form-control"
                           placeholder="votre@email.com"
                           required
                           autofocus>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Mot de passe</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input type="password"
                           id="password"
                           name="password"
                           class="form-control"
                           placeholder="Votre mot de passe"
                           required>
                    <button type="button" class="toggle-password" onclick="togglePasswordVisibility()" tabindex="-1">
                        <i class="fas fa-eye" id="togglePwdIcon"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn-login">
                    <i class="fas fa-arrow-right-to-bracket"></i>&nbsp; Se connecter
                </button>
            </div>
        </form>

        <div class="auth-links">
            <p><a th:href="@{/forgot-password}">Mot de passe oublié ?</a></p>
            <div class="divider">ou</div>
            <p>Pas encore de compte ? <a th:href="@{/subscription/pricing}">Créer un compte</a></p>
            <p style="margin-top: 14px;"><a th:href="@{/}"><i class="fas fa-arrow-left"></i> Retour à l'accueil</a></p>
        </div>
    </div>

    <script>
    function togglePasswordVisibility() {
        var pwd = document.getElementById('password');
        var icon = document.getElementById('togglePwdIcon');
        if (pwd.type === 'password') {
            pwd.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            pwd.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
    </script>
</body>
</html>
        /* === DocAvocat SaaS 2026 — Auth Page === */
        :root {
            --brand-500: #1E3A5F;
            --brand-700: #14253F;
            --text-primary: #1A202C;
            --text-secondary: #6B7280;
            --text-tertiary: #9CA3AF;
            --bg-primary: #FFFFFF;
            --bg-secondary: #F8FAFC;
            --border: #E2E8F0;
            --success: #10B981;
            --error: #EF4444;
            --radius-md: 10px;
            --radius-lg: 16px;
        }
        
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: var(--text-primary);
            background: var(--bg-secondary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            display: flex;
            min-height: 100vh;
        }
        
        /* Left Panel — Brand Hero */
        .auth-left {
            flex: 1;
            background: linear-gradient(135deg, #1E3A5F 0%, #14253F 100%);
            color: white;
            padding: 48px;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }
        
        .auth-left::before {
            content: '';
            position: absolute;
            top: -100px;
            right: -100px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255,255,255,.1) 0%, transparent 70%);
            pointer-events: none;
        }
        
        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 60px;
            position: relative;
            z-index: 1;
        }
        
        .brand-icon {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,.15);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
        }
        
        .brand-name {
            font-size: 24px;
            font-weight: 800;
            color: white;
        }
        
        .auth-left-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            z-index: 1;
        }
        
        .auth-left h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 16px;
            line-height: 1.2;
            color: white;
        }
        
        .auth-left > p, .auth-left-content > p {
            font-size: 1.125rem;
            color: rgba(255,255,255,.85);
            margin-bottom: 40px;
            line-height: 1.6;
        }
        
        .features-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .features-list li {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px 0;
            color: rgba(255,255,255,.9);
            font-size: 15px;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }
        
        .features-list li:last-child {
            border-bottom: none;
        }
        
        .feature-icon {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        
        .feature-icon i {
            color: white;
            font-size: 18px;
        }
        
        /* Right Panel — Login Form */
        .auth-right {
            flex: 1;
            background: white;
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            max-width: 540px;
        }
        
        .auth-right h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 8px;
            color: var(--text-primary);
        }
        
        .subtitle {
            color: var(--text-secondary);
            margin-bottom: 32px;
            font-size: 15px;
        }
        
        /* Alerts */
        .alert {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border-radius: var(--radius-md);
            margin-bottom: 24px;
            font-size: 14px;
        }
        
        .alert i {
            font-size: 18px;
            flex-shrink: 0;
        }
        
        .alert-danger {
            background: #FEF2F2;
            color: #991B1B;
            border: 1px solid #FEE2E2;
        }
        
        .alert-success {
            background: #F0FDF4;
            color: #166534;
            border: 1px solid #BBF7D0;
        }
        
        /* Form */
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-label {
            display: block;
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 8px;
            color: var(--text-primary);
        }
        
        .input-wrapper {
            position: relative;
        }
        
        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-tertiary);
            font-size: 16px;
            pointer-events: none;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 14px 12px 44px;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            font-size: 15px;
            font-family: inherit;
            transition: all .2s;
            background: var(--bg-primary);
        }
        
        .form-control:focus {
            outline: none;
            border-color: var(--brand-500);
            box-shadow: 0 0 0 3px rgba(30,58,95,.08);
        }
        
        .toggle-password {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--text-tertiary);
            cursor: pointer;
            padding: 4px;
            font-size: 16px;
            transition: color .2s;
        }
        
        .toggle-password:hover {
            color: var(--text-secondary);
        }
        
        .btn-login {
            width: 100%;
            padding: 14px;
            background: var(--brand-500);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        
        .btn-login:hover {
            background: var(--brand-700);
            box-shadow: 0 4px 12px rgba(30,58,95,.2);
            transform: translateY(-1px);
        }
        
        .btn-login:active {
            transform: translateY(0);
        }
        
        /* Auth Links */
        .auth-links {
            margin-top: 24px;
            text-align: center;
        }
        
        .auth-links p {
            font-size: 14px;
            color: var(--text-secondary);
            margin: 10px 0;
        }
        
        .auth-links a {
            color: var(--brand-500);
            text-decoration: none;
            font-weight: 600;
            transition: color .2s;
        }
        
        .auth-links a:hover {
            color: var(--brand-700);
            text-decoration: underline;
        }
        
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 20px 0;
            color: var(--text-tertiary);
            font-size: 13px;
        }
        
        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid var(--border);
        }
        
        .divider::before {
            margin-right: 12px;
        }
        
        .divider::after {
            margin-left: 12px;
        }
        
        /* Responsive */
        @media (max-width: 968px) {
            body {
                flex-direction: column;
            }
            
            .auth-left {
                padding: 32px 24px;
                min-height: 300px;
            }
            
            .auth-left h2 {
                font-size: 2rem;
            }
            
            .features-list {
                display: none;
            }
            
            .auth-right {
                max-width: 100%;
                padding: 32px 24px;
            }
        }
    </style>
</head>
<body>
    <!-- Left Panel — Brand Hero -->
    <div class="auth-left">
        <div class="brand-logo">
            <div class="brand-icon"><i class="fas fa-scale-balanced"></i></div>
            <span class="brand-name">DocAvocat</span>
        </div>
        <div class="auth-left-content">
            <h2>Espace professionnel<br>sécurisé</h2>
            <p>Portail de gestion documentaire dédié aux cabinets d'avocats. Dossiers, documents, clients et signatures électroniques.</p>
            <ul class="features-list">
                <li>
                    <div class="feature-icon"><i class="fas fa-folder-open"></i></div>
                    <span>Gestion centralisée des dossiers</span>
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-file-signature"></i></div>
                    <span>Signatures électroniques Yousign</span>
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-shield-halved"></i></div>
                    <span>Sécurité et conformité RGPD</span>
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-gavel"></i></div>
                    <span>Intégration RPVA / e-Barreau</span>
                </li>
            </ul>
        </div>
    </div>

    <!-- Right Panel — Login Form -->
    <div class="auth-right">
        <h1>Accès au portail</h1>
        <p class="subtitle">Connectez-vous à votre espace DocAvocat</p>

        <div th:if="${param.error}" class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            <span th:text="${error} ?: 'Email ou mot de passe incorrect'"></span>
        </div>

        <div th:if="${message}" class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            <span th:text="${message}"></span>
        </div>

        <form th:action="@{/login}" method="post">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}"/>
            <div class="form-group">
                <label class="form-label" for="email">Adresse e-mail</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input type="email"
                           id="email"
                           name="email"
                           class="form-control"
                           placeholder="votre@email.com"
                           required
                           autofocus
                           autocomplete="email">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Mot de passe</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input type="password"
                           id="password"
                           name="password"
                           class="form-control"
                           placeholder="Votre mot de passe"
                           required
                           autocomplete="current-password">
                    <button type="button" class="toggle-password" onclick="togglePasswordVisibility()" tabindex="-1" aria-label="Afficher le mot de passe">
                        <i class="fas fa-eye" id="togglePwdIcon"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn-login">
                    <i class="fas fa-arrow-right-to-bracket"></i> Se connecter
                </button>
            </div>
        </form>

        <div class="auth-links">
            <p><a th:href="@{/forgot-password}">Mot de passe oublié ?</a></p>
            <div class="divider">ou</div>
            <p>Pas encore de compte ? <a th:href="@{/subscription/pricing}">Créer un compte</a></p>
            <p style="margin-top: 14px;"><a th:href="@{/}" style="color: var(--text-tertiary);"><i class="fas fa-arrow-left" style="font-size: 12px;"></i> Retour à l'accueil</a></p>
        </div>
    </div>

    <script>
    function togglePasswordVisibility() {
        var pwd = document.getElementById('password');
        var icon = document.getElementById('togglePwdIcon');
        if (pwd.type === 'password') {
            pwd.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            pwd.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
    </script>
</body>
</html>