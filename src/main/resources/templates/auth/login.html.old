<!DOCTYPE html>
<html lang="fr" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion â€” DocAvocat</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link th:href="@{/webjars/bootstrap/5.3.0/css/bootstrap.min.css}" rel="stylesheet">
    <link th:href="@{/webjars/font-awesome/6.4.0/css/all.min.css}" rel="stylesheet">
    <link th:href="@{/css/pages/auth.css}" rel="stylesheet">
</head>
<body>
    <!-- Left Panel â€” Brand Hero -->
    <div class="auth-left">
        <div class="brand-logo">
            <div class="brand-icon"><i class="fas fa-scale-balanced"></i></div>
            <span class="brand-name">DocAvocat</span>
        </div>
        <div class="auth-left-content">
            <h2>Espace professionnel<br>sÃ©curisÃ©</h2>
            <p>Portail de gestion documentaire dÃ©diÃ© aux cabinets d'avocats. Dossiers, documents, clients et signatures Ã©lectroniques.</p>
            <ul class="features-list">
                <li>
                    <div class="feature-icon"><i class="fas fa-folder-open"></i></div>
                    <span>Gestion centralisÃ©e des dossiers</span>
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-file-signature"></i></div>
                    <span>Signatures Ã©lectroniques Yousign</span>
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-shield-halved"></i></div>
                    <span>SÃ©curitÃ© et conformitÃ© RGPD</span>
                </li>
                <li>
                    <div class="feature-icon"><i class="fas fa-gavel"></i></div>
                    <span>IntÃ©gration RPVA / e-Barreau</span>
                </li>
            </ul>
        </div>
    </div>

    <!-- Right Panel â€” Login Form -->
    <div class="auth-right">
        <h1>AccÃ¨s au portail</h1>
        <p class="subtitle">Connectez-vous Ã  votre espace DocAvocat</p>

        <div th:if="${param.error}" class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            <span th:text="${error} ?: 'Email ou mot de passe incorrect'"></span>
        </div>

        <div th:if="${message}" class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            <span th:text="${message}"></span>
        </div>

        <form th:action="@{/login}" method="post">
            <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}"/>
            <div class="form-group">
                <label class="form-label" for="email">Adresse e-mail</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input type="email"
                           id="email"
                           name="email"
                           class="form-control"
                           placeholder="votre@email.com"
                           required
                           autofocus
                           autocomplete="email">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Mot de passe</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input type="password"
                           id="password"
                           name="password"
                           class="form-control"
                           placeholder="Votre mot de passe"
                           required
                           autocomplete="current-password">
                    <button type="button" class="toggle-password" onclick="togglePasswordVisibility()" tabindex="-1" aria-label="Afficher le mot de passe">
                        <i class="fas fa-eye" id="togglePwdIcon"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn-login">
                    <i class="fas fa-arrow-right-to-bracket"></i> Se connecter
                </button>
            </div>
        </form>

        <div class="auth-links">
            <p><a th:href="@{/forgot-password}">Mot de passe oubliÃ© ?</a></p>
            <div class="divider">ou</div>
            <p>Pas encore de compte ? <a th:href="@{/subscription/pricing}">CrÃ©er un compte</a></p>
            <p style="margin-top: 14px;"><a th:href="@{/}" style="color: var(--text-tertiary);"><i class="fas fa-arrow-left" style="font-size: 12px;"></i> Retour Ã  l'accueil</a></p>
        </div>
    </div>

    <script>
    function togglePasswordVisibility() {
        var pwd = document.getElementById('password');
        var icon = document.getElementById('togglePwdIcon');
        if (pwd.type === 'password') {
            pwd.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            pwd.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
    </script>
</body>
</html>
