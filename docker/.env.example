# ============================================================
# DocAvocat - Production Environment Variables
# ============================================================
# IMPORTANT: Copier ce fichier vers .env et remplir les valeurs
# cp .env.example .env
# ============================================================

# ── Application Docker Image ────────────────────────────────
# Image construite localement ou depuis le registry
APP_IMAGE=docavocat-app:latest

# ── Base de données MySQL ───────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── JWT Authentication ──────────────────────────────────────
# Générer avec: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# ── Email SMTP (SendGrid, Mailgun, Gmail, etc.) ────────────
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=CHANGE_ME_SENDGRID_API_KEY

# ── Services externes ───────────────────────────────────────
# YouSign (signature électronique)
YOUSIGN_API_KEY=CHANGE_ME_YOUSIGN_API_KEY

# Stripe (paiements) - Optionnel
STRIPE_API_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ── Maintenance Mode ────────────────────────────────────────
MAINTENANCE_ENABLED=false

# ── Monitoring (Grafana) ────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_SECURE_PASSWORD
