# ============================================================
# DocAvocat - Production Environment Variables
# ============================================================
# IMPORTANT: Copier ce fichier vers .env et remplir les valeurs
# cp .env.example .env
# ============================================================

# ── Application Docker Image ────────────────────────────────
# Image construite localement ou depuis le registry
APP_IMAGE=docavocat-app:latest

# ── Base de données MySQL ───────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── JWT Authentication ──────────────────────────────────────
# Générer avec: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# ── MFA Encryption (AES-256-GCM) ───────────────────────────
# Clé pour chiffrer les secrets TOTP en base de données
# Générer avec: openssl rand -base64 32
MFA_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# ── Email SMTP (SendGrid, Mailgun, Gmail, etc.) ────────────
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=CHANGE_ME_SENDGRID_API_KEY

# ── Services externes ───────────────────────────────────────
# YouSign (signature électronique)
YOUSIGN_API_KEY=CHANGE_ME_YOUSIGN_API_KEY

# Stripe (paiements) - Optionnel
STRIPE_API_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME

# ── MinIO (stockage S3 — CX23 Hetzner réseau privé) ─────────
# Identifiants créés sur le serveur CX23 lors du setup MinIO
MINIO_ACCESS_KEY=gedavocat-admin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY

# ── Maintenance Mode ────────────────────────────────────────
MAINTENANCE_ENABLED=false

# ── Monitoring (Grafana) ────────────────────────────────────
# IMPORTANT : ne jamais laisser les valeurs par défaut en production !
# Utilisateur admin Grafana
GRAFANA_ADMIN_USER=admin
# Mot de passe admin Grafana (minimum 12 caractères, complexe)
# Générer avec : openssl rand -base64 24
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_SECURE_PASSWORD
# Clé secrète Grafana pour le chiffrement interne (cookies, tokens)
# Générer avec : openssl rand -base64 32
GRAFANA_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
