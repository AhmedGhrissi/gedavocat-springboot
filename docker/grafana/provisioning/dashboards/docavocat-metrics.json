{
  "annotations": { "list": [] },
  "description": "Métriques Prometheus — CPU, RAM, Disk, MySQL, JVM, HTTP, Alertes",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Système (Node Exporter)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }] } } },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 101,
      "title": "CPU Usage (%)",
      "type": "gauge",
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 102,
      "title": "Memory Usage (%)",
      "type": "gauge",
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "RAM" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 103,
      "title": "Disk Usage (%)",
      "type": "gauge",
      "targets": [{ "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)", "legendFormat": "Disk" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 104,
      "title": "Disk Free",
      "type": "stat",
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"}", "legendFormat": "Free" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 200,
      "title": "Application Spring Boot",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0 }] } } },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 8 },
      "id": 201,
      "title": "App UP",
      "type": "stat",
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{job=\"docavocat-app\"}", "legendFormat": "UP" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 5, "w": 10, "x": 4, "y": 8 },
      "id": 202,
      "title": "HTTP Requests Rate (req/s)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count[5m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 5, "w": 10, "x": 14, "y": 8 },
      "id": 203,
      "title": "HTTP Response Time (P95)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))", "legendFormat": "P50" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 13 },
      "id": 204,
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "Used {{id}}" },
        { "expr": "jvm_memory_max_bytes{area=\"heap\"}", "legendFormat": "Max {{id}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 13 },
      "id": 205,
      "title": "JVM Threads",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "Live" },
        { "expr": "jvm_threads_daemon_threads", "legendFormat": "Daemon" },
        { "expr": "jvm_threads_peak_threads", "legendFormat": "Peak" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "title": "MySQL",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 150 }] } } },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 19 },
      "id": 301,
      "title": "MySQL Connections",
      "type": "gauge",
      "targets": [{ "expr": "mysql_global_status_threads_connected", "legendFormat": "Connected" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 5, "w": 9, "x": 6, "y": 19 },
      "id": 302,
      "title": "MySQL Queries/s",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(mysql_global_status_queries[5m])", "legendFormat": "Queries/s" },
        { "expr": "rate(mysql_global_status_slow_queries[5m])", "legendFormat": "Slow Queries/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 5, "w": 9, "x": 15, "y": 19 },
      "id": 303,
      "title": "MySQL InnoDB Buffer Pool",
      "type": "timeseries",
      "targets": [
        { "expr": "mysql_global_status_innodb_buffer_pool_bytes_data", "legendFormat": "Data" },
        { "expr": "mysql_global_variables_innodb_buffer_pool_size", "legendFormat": "Pool Size" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 400,
      "title": "Docker Containers (cAdvisor)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 25 },
      "id": 401,
      "title": "Container CPU Usage (%)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{name=~\"docavocat.*\"}[5m]) * 100", "legendFormat": "{{name}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 25 },
      "id": 402,
      "title": "Container Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "container_memory_usage_bytes{name=~\"docavocat.*\"}", "legendFormat": "{{name}}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 500,
      "title": "Alertes Prometheus",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 32 },
      "id": 501,
      "title": "Alertes actives",
      "type": "table",
      "targets": [
        { "expr": "ALERTS{alertstate=\"firing\"}", "format": "table", "legendFormat": "", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "alertstate": true }, "renameByName": { "alertname": "Alerte", "severity": "Sévérité", "instance": "Instance", "Value": "Status" } } }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["docavocat", "prometheus", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Paris",
  "title": "DocAvocat — Métriques Infrastructure",
  "uid": "docavocat-metrics",
  "version": 1
}
